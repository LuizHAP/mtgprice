# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mtgprice

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-generate-with-openssl-rand-base64-32

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-telegram-chat-id
BOT_PASSWORD=your-bot-password-for-authentication

# Application
NODE_ENV=development
PORT=3000

# Price Source API Keys (Optional)
TCGPLAYER_BEARER_TOKEN=
CARDMARKET_APP_TOKEN=
CARDMARKET_APP_SECRET=
CARDKINGDOM_API_KEY=

# Scheduler
AUTO_COLLECT_PRICES=true
CRON_MORNING=0 9 * * *
CRON_AFTERNOON=0 15 * * *
CRON_EVENING=0 21 * * *
CRON_METAGAME_REFRESH=0 2 * * 0

# Opportunity Detection (Phase 4)
DETECT_DROP_THRESHOLD=0.15
DETECT_LOOKBACK_DAYS=7
DETECT_BASELINE_DAYS=30
DETECT_COOLDOWN_DAYS=7
DETECT_MIN_HISTORY_DAYS=30

# Scraper Reliability & Performance (Phase 6)
# Per-source concurrency cap for fetchAllPrices (D-08/D-09).
# 5 concurrent × 4 sources = up to 20 in-flight requests, within rate limit budgets.
SCRAPER_CONCURRENCY_PER_SOURCE=5

# Retry layer wrapping each external fetch (D-05/D-06).
# 3 attempts with exponential backoff (1s, 2s) before the circuit breaker counts a failure.
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_RETRY_BASE_DELAY_MS=1000
