{
  "name": "mtg-price-monitor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "bot:dev": "tsx src/bot/index.ts",
    "bot:start": "node dist/bot/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.38.4",
    "grammy": "^1.36.2",
    "ioredis": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.2.3",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^3.0.9",
    "drizzle-kit": "^0.30.4",
    "husky": "^9.1.7",
    "jsdom": "^26.0.3",
    "lint-staged": "^15.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.9"
  },
  "lint-staged": {
    "*": ["biome check --write --no-errors-on-unmatched"]
  }
}
